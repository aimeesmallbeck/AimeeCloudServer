# Copy this file to .env and fill in real values.

# Optional fallback demo keys (used only when the SQLite API-key lookup fails)
AIMEE_DEMO_KEY_FREE=ac_free_demo_12345
AIMEE_DEMO_KEY_PAID=ac_paid_demo_67890

# OpenRouter (used by vision analysis and HTTP API LLM)
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_HTTP_API_KEY=your-openrouter-api-key

# Google OAuth (optional)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ElevenLabs TTS (optional)
ELEVENLABS_API_KEY=your-elevenlabs-api-key

# Gemini / Google AI (required for audio streaming)
GEMINI_API_KEY=your-gemini-api-key

# JWT signing secret (generate a strong random value)
JWT_SECRET=generate-a-strong-random-secret

# Admin dashboard token
ADMIN_TOKEN=generate-a-strong-admin-token

# SQLite database path
AIMEECLOUD_DB=/workspace/aimeecloud.db
